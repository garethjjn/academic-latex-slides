{
  "schema": "academic-latex-slides/template@1",
  "id": "msu",
  "name": "Michigan State University",
  "summary": "Green academic palette, classic Beamer feel",
  "good_fit": ["general talks", "seminars", "internal presentations"],
  "status": "stable",
  "engine": "xelatex",
  "documentclass": "ctexbeamer",
  "entry": "main.tex.template",
  "placeholders": ["TITLE", "SHORT_TITLE", "SUBTITLE", "AUTHOR",
                   "INSTITUTE", "SHORT_INSTITUTE", "DATE", "SECTION_INPUTS"],
  "capabilities": {
    "subtitle": "optional",
    "empty_subtitle": "omit-line",
    "section_divider": true,
    "title_graphic": true,
    "cjk": true
  },
  "escape_profile": "latex-standard",
  "assets": [
    {
      "file": "msu.png",
      "purpose": "title-page graphic",
      "source": "Michigan State University visual identity",
      "license": "institutional identity; minimal runtime subset bundled for compile-out-of-the-box; removable"
    },
    {
      "file": "Logo.png",
      "purpose": "per-page corner logo",
      "source": "Michigan State University visual identity",
      "license": "institutional identity; minimal runtime subset bundled for compile-out-of-the-box; removable"
    }
  ],
  "min_scaffold": "1.0.0",
  "maintainer": "Gareth Jiang"
}
