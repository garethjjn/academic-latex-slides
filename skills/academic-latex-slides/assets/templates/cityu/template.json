{
  "schema": "academic-latex-slides/template@1",
  "id": "cityu",
  "name": "City University of Hong Kong",
  "summary": "Purple academic palette, restrained clean title page",
  "good_fit": ["compact lectures", "concise reports", "clean seminars"],
  "status": "stable",
  "engine": "xelatex",
  "documentclass": "ctexbeamer",
  "entry": "main.tex.template",
  "placeholders": ["TITLE", "SHORT_TITLE", "SUBTITLE", "AUTHOR",
                   "INSTITUTE", "SHORT_INSTITUTE", "DATE", "SECTION_INPUTS"],
  "capabilities": {
    "subtitle": "optional",
    "empty_subtitle": "omit-line",
    "section_divider": true,
    "title_graphic": true,
    "cjk": true
  },
  "escape_profile": "latex-standard",
  "assets": [
    {
      "file": "CityULogo.pdf",
      "purpose": "title-page logo",
      "source": "City University of Hong Kong visual identity",
      "license": "institutional identity; minimal runtime subset bundled for compile-out-of-the-box; removable"
    }
  ],
  "min_scaffold": "1.0.0",
  "maintainer": "Gareth Jiang"
}
